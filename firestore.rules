rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function brandPath(brandID) {
      return /databases/$(database)/documents/brands/$(brandID);
    }

    function brandData(brandID) {
      return get(brandPath(brandID)).data;
    }

    function hasBrandWriteAccess(brandID) {
      return signedIn()
        && exists(brandPath(brandID))
        && (
          (
            brandData(brandID).ownerUIDs is list
            && brandData(brandID).ownerUIDs.hasAny([request.auth.uid])
          )
          || (
            brandData(brandID).adminUIDs is list
            && brandData(brandID).adminUIDs.hasAny([request.auth.uid])
          )
        );
    }

    function roomPath(roomID) {
      return /databases/$(database)/documents/Rooms/$(roomID);
    }

    function roomMemberPath(roomID, uid) {
      return /databases/$(database)/documents/Rooms/$(roomID)/members/$(uid);
    }

    function isRoomParticipant(roomID) {
      return signedIn()
        && exists(roomPath(roomID))
        && exists(roomMemberPath(roomID, request.auth.uid));
    }

    function isRoomCreator(roomID) {
      return signedIn()
        && exists(roomPath(roomID))
        && get(roomPath(roomID)).data.creatorUID == request.auth.uid;
    }

    function createsRoomMember(roomID, uid) {
      return signedIn()
        && uid == request.auth.uid
        && request.resource.data.userID == uid
        && request.resource.data.role in ["owner", "member"]
        && request.resource.data.keys().hasOnly([
          "userID",
          "role",
          "joinedAt",
          "displayNameSnapshot",
          "avatarPathSnapshot",
          "createdAt",
          "updatedAt"
        ])
        && existsAfter(roomPath(roomID))
        && (
          (
            getAfter(roomPath(roomID)).data.creatorUID == uid
            && request.resource.data.role == "owner"
          )
          || (
            getAfter(roomPath(roomID)).data.creatorUID != uid
            && request.resource.data.role == "member"
          )
        );
    }

    function userProfileWriteDoesNotTouchJoinedRooms(userID) {
      return signedIn()
        && request.auth.uid == userID
        && (
          (
            !exists(/databases/$(database)/documents/users/$(userID))
            && !request.resource.data.keys().hasAny(["joinedRooms"])
          )
          || (
            exists(/databases/$(database)/documents/users/$(userID))
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["joinedRooms"])
          )
        );
    }

    function validLastReadSeqUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["lastReadSeq", "updatedAt"])
        && request.resource.data.lastReadSeq is int
        && (
          !("lastReadSeq" in resource.data)
          || request.resource.data.lastReadSeq >= resource.data.lastReadSeq
        );
    }

    function validJoinedRoomCreate(userID, roomID) {
      return signedIn()
        && request.auth.uid == userID
        && request.resource.data.roomID == roomID
        && request.resource.data.role in ["owner", "member"]
        && request.resource.data.keys().hasOnly([
          "roomID",
          "role",
          "joinedAt",
          "lastReadSeq",
          "isClosed",
          "updatedAt"
        ])
        && existsAfter(roomMemberPath(roomID, userID));
    }

    function validRoomMemberCountUpdate(roomID) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberCount", "updatedAt"])
        && request.resource.data.memberCount is int
        && request.resource.data.memberCount >= 0
        && (
          (
            existsAfter(roomMemberPath(roomID, request.auth.uid))
            && !exists(roomMemberPath(roomID, request.auth.uid))
            && request.resource.data.memberCount == resource.data.memberCount + 1
          )
          || (
            !existsAfter(roomMemberPath(roomID, request.auth.uid))
            && exists(roomMemberPath(roomID, request.auth.uid))
            && request.resource.data.memberCount == resource.data.memberCount - 1
          )
        );
    }

    match /brandAdmins/{adminID} {
      allow read, write: if false;
    }

    match /brandRequests/{requestID} {
      allow read, write: if false;
    }

    match /brandRequestNameIndex/{normalizedBrandNameHash} {
      allow read, write: if false;
    }

    match /brandRequestDailyCounters/{userID}/brandRequestDays/{dateKey} {
      allow read, write: if false;
    }

    match /brandRequestUserLimits/{userID} {
      allow read, write: if false;
    }

    match /brands/{brandID} {
      allow read: if true;
      allow create, update, delete: if false;

      match /seasons/{seasonID} {
        allow read: if true;
        allow create, update, delete: if hasBrandWriteAccess(brandID);

        match /posts/{postID} {
          allow read: if true;
          allow create, update, delete: if hasBrandWriteAccess(brandID);

          match /comments/{commentID} {
            allow read: if true;
            allow create, update, delete: if false;
          }

          match /replacements/{replacementID} {
            allow read: if true;
            allow create, update, delete: if hasBrandWriteAccess(brandID);
          }
        }
      }

      match /importJobs/{jobID} {
        allow read: if hasBrandWriteAccess(brandID);
        allow create, update, delete: if false;
      }

      match /seasonCandidates/{candidateID} {
        allow read: if hasBrandWriteAccess(brandID);
        allow create, update, delete: if false;
      }
    }

    match /userIdentities/{identityKey} {
      // 사용자 매핑 컬렉션은 더 이상 사용하지 않고 users/{request.auth.uid}를 canonical 문서로 사용한다.
      allow read, write: if false;
    }

    match /users/{userID} {
      allow read: if signedIn();
      allow create, update: if userProfileWriteDoesNotTouchJoinedRooms(userID);
      allow delete: if false;

      match /postStates/{stateID} {
        allow read: if signedIn() && request.auth.uid == userID;
        allow create, update, delete: if false;
      }

      match /brandStates/{stateID} {
        allow read: if signedIn() && request.auth.uid == userID;
        allow create, update, delete: if false;
      }

      match /seasonStates/{stateID} {
        allow read: if signedIn() && request.auth.uid == userID;
        allow create, update, delete: if false;
      }

      match /commentStates/{stateID} {
        allow read: if signedIn() && request.auth.uid == userID;
        allow create, update, delete: if false;
      }

      match /blockedUsers/{blockedUserID} {
        allow read: if signedIn() && request.auth.uid == userID;
        allow create, update, delete: if false;
      }

      match /roomStates/{roomID} {
        allow read: if signedIn() && request.auth.uid == userID;
        allow create, update, delete: if false;
      }

      match /joinedRooms/{roomID} {
        allow read: if signedIn() && request.auth.uid == userID;
        allow create: if validJoinedRoomCreate(userID, roomID);
        allow update: if signedIn()
          && request.auth.uid == userID
          && validLastReadSeqUpdate();
        allow delete: if signedIn()
          && request.auth.uid == userID
          && !existsAfter(roomMemberPath(roomID, userID));
      }

      match /meta/session {
        allow read, write: if signedIn() && request.auth.uid == userID;
      }

      match /devices/{deviceID} {
        allow read, write: if signedIn() && request.auth.uid == userID;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /commentReports/{reportID} {
      allow read, write: if false;
    }

    match /Rooms/{roomID} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.creatorUID == request.auth.uid
        && !request.resource.data.keys().hasAny(["participantUIDs"])
        && request.resource.data.keys().hasAll([
          "creatorUID",
          "memberCount",
          "isClosed"
        ]);
      allow update: if signedIn()
        && (
          (
            isRoomCreator(roomID)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              "creatorUID",
              "participantUIDs",
              "seq",
              "lastMessage",
              "lastMessageAt",
              "lastMessageSeq"
            ])
          )
          || validRoomMemberCountUpdate(roomID)
        );
      allow delete: if false;

      match /Messages/{messageID} {
        allow read: if signedIn();
        allow write: if isRoomParticipant(roomID);
      }

      match /mediaIndex/{mediaID} {
        allow read: if signedIn();
        allow write: if isRoomParticipant(roomID);
      }

      match /members/{uid} {
        allow read: if isRoomParticipant(roomID);
        allow create: if createsRoomMember(roomID, uid);
        allow delete: if signedIn()
          && request.auth.uid == uid
          && !isRoomCreator(roomID);
        allow update: if false;
      }

      match /{document=**} {
        allow read, write: if isRoomParticipant(roomID);
      }
    }

    match /tags/{tagID} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /tagAliases/{tagAliasID} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /tagConcepts/{tagConceptID} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
